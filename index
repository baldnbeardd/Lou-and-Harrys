                    <span id="cart-total">$0.00</span>
                </div>
                
                <button onclick="checkoutWithShopify()" 
                        class="w-full bg-[#1e3a5f] hover:bg-[#152b47] text-white py-4 rounded-2xl font-semibold text-lg transition-colors">
                    Checkout with Shopify
                </button>
                <p class="text-center text-xs text-gray-500 mt-3">Secure checkout powered by Shopify</p>
            </div>
        </div>
    </div>

    <script>
        // Tailwind script
        function initializeTailwind() {
            document.documentElement.style.setProperty('--accent-gold', '#c9a227');
        }

        // Mobile Menu
        const mobileBtn = document.getElementById('mobile-menu-btn');
        mobileBtn.addEventListener('click', () => {
            const nav = document.createElement('div');
            nav.className = `fixed inset-0 bg-white z-[200] p-8 md:hidden`;
            nav.innerHTML = `
                <div class="flex justify-between mb-10">
                    <div class="font-bold text-3xl tracking-tighter">Lou &amp; Harry's</div>
                    <button class="text-4xl">×</button>
                </div>
                <div class="flex flex-col gap-y-6 text-2xl font-medium">
                    <a href="#menu" class="py-2">Menu</a>
                    <a href="#locations" class="py-2">Locations</a>
                    <a href="#catering" class="py-2">Catering</a>
                    <a href="#shop" class="py-2">Shop</a>
                    <a href="https://order.toasttab.com/online/lou-harry-s-grill-bakery" target="_blank" 
                       class="mt-6 bg-[#1e3a5f] text-white text-center py-4 rounded-2xl">Order Online</a>
                </div>
            `;
            document.body.appendChild(nav);
            nav.querySelector('button').onclick = () => nav.remove();
            nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => nav.remove()));
        });

        // Products data
        const products = [
            {
                id: 1,
                name: "Mama’s Greek Dressing",
                price: 12.99,
                desc: "Our signature 16oz bottle — the same one used in the restaurant",
                img: "https://picsum.photos/id/312/600/400"
            },
            {
                id: 2,
                name: "Greek Marinade",
                price: 11.99,
                desc: "Perfect for chicken, pork, or vegetables. 16oz",
                img: "https://picsum.photos/id/160/600/400"
            },
            {
                id: 3,
                name: "Lou & Harry's Logo Tee",
                price: 29.99,
                desc: "Premium cotton. Navy or white. Unisex sizing.",
                img: "https://picsum.photos/id/201/600/400"
            },
            {
                id: 4,
                name: "Catering Gift Card",
                price: 50.00,
                desc: "Give the gift of great Greek food. Digital delivery.",
                img: "https://picsum.photos/id/292/600/400"
            }
        ];

        let cart = [];

        function renderProducts() {
            const container = document.getElementById('product-grid');
            container.innerHTML = '';
            
            products.forEach(product => {
                const card = document.createElement('div');
                card.className = `food-card bg-white border border-gray-100 rounded-3xl overflow-hidden flex flex-col`;
                card.innerHTML = `
                    <img src="${product.img}" class="w-full h-56 object-cover" alt="${product.name}">
                    <div class="p-6 flex flex-col flex-1">
                        <div class="flex-1">
                            <h3 class="font-semibold text-xl">${product.name}</h3>
                            <p class="text-sm text-gray-600 mt-2">${product.desc}</p>
                        </div>
                        
                        <div class="flex items-center justify-between mt-6">
                            <div class="font-semibold text-2xl">$${product.price.toFixed(2)}</div>
                            <button onclick="addToCart(${product.id})" 
                                    class="bg-[#1e3a5f] hover:bg-[#152b47] transition-colors text-white px-6 py-2.5 rounded-2xl text-sm font-semibold flex items-center gap-x-2">
                                <i class="fas fa-plus"></i>
                                <span>Add</span>
                            </button>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            const existing = cart.find(item => item.id === productId);
            
            if (existing) {
                existing.quantity++;
            } else {
                cart.push({...product, quantity: 1});
            }
            
            // Show mini feedback
            const btns = document.querySelectorAll(`button[onclick="addToCart(${productId})"]`);
            btns.forEach(btn => {
                const originalText = btn.innerHTML;
                btn.innerHTML = `<i class="fas fa-check"></i> Added!`;
                setTimeout(() => {
                    btn.innerHTML = originalText;
                }, 1200);
            });
            
            updateCartCount();
        }

        function updateCartCount() {
            // Could add a cart icon in nav if desired
        }

        function showCart() {
            const modal = document.getElementById('cart-modal');
            const itemsContainer = document.getElementById('cart-items');
            itemsContainer.innerHTML = '';
            
            let total = 0;
            
            if (cart.length === 0) {
                itemsContainer.innerHTML = `<p class="text-center py-8 text-gray-400">Your cart is empty</p>`;
            } else {
                cart.forEach((item, index) => {
                    const itemTotal = item.price * item.quantity;
                    total += itemTotal;
                    
                    const div = document.createElement('div');
                    div.className = `flex gap-4 border-b pb-4`;
                    div.innerHTML = `
                        <img src="${item.img}" class="w-16 h-16 rounded-2xl object-cover flex-shrink-0">
                        <div class="flex-1 min-w-0">
                            <div class="font-medium">${item.name}</div>
                            <div class="text-sm text-gray-500">$${item.price.toFixed(2)} × ${item.quantity}</div>
                            
                            <div class="flex items-center gap-x-3 mt-2">
                                <button onclick="changeQuantity(${index}, -1)" class="w-8 h-8 flex items-center justify-center border rounded-xl hover:bg-gray-100">-</button>
                                <span class="font-medium w-6 text-center">${item.quantity}</span>
                                <button onclick="changeQuantity(${index}, 1)" class="w-8 h-8 flex items-center justify-center border rounded-xl hover:bg-gray-100">+</button>
                                <button onclick="removeFromCart(${index})" class="ml-auto text-red-400 hover:text-red-500 text-sm">Remove</button>
                            </div>
                        </div>
                        <div class="font-semibold text-right">$${itemTotal.toFixed(2)}</div>
                    `;
                    itemsContainer.appendChild(div);
                });
            }
            
            document.getElementById('cart-total').textContent = `$${total.toFixed(2)}`;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function changeQuantity(index, delta) {
            cart[index].quantity += delta;
            if (cart[index].quantity < 1) cart[index].quantity = 1;
            showCart();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            showCart();
        }

        function hideCart() {
            const modal = document.getElementById('cart-modal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }

        function checkoutWithShopify() {
            hideCart();
            // In real implementation, this would redirect to your Shopify checkout
            // or trigger Shopify Buy Button checkout
            alert("In production: This would redirect to your Shopify store checkout with the cart items.");
            
            // Example: window.location.href = "https://your-shopify-store.myshopify.com/cart";
        }

        function showShopifyInstructions() {
            const area = document.getElementById('shopify-embed-area');
            area.classList.remove('hidden');
            area.innerHTML = `
                <div class="max-w-md mx-auto text-left text-sm">
                    <p class="font-semibold mb-3 text-[#1e3a5f]">How to embed your Shopify store:</p>
                    <ol class="list-decimal list-inside space-y-2 text-gray-600">
                        <li>Go to your Shopify admin → Sales channels → Buy Button</li>
                        <li>Choose products or collections you want to sell</li>
                        <li>Copy the generated embed code</li>
                        <li>Paste it inside the div with id <code class="bg-gray-100 px-1">shopify-embed-area</code></li>
                    </ol>
                    <p class="mt-4 text-xs">You can also embed a full collection page using Shopify's storefront embed.</p>
                </div>
            `;
        }

        // Contact form handler
        document.getElementById('contact-form').addEventListener('submit', function(e) {
            e.preventDefault();
            const btn = this.querySelector('button');
            const originalText = btn.innerHTML;
            btn.innerHTML = 'Sending...';
            btn.disabled = true;
            
            setTimeout(() => {
                btn.innerHTML = 'Message Sent! ✓';
                setTimeout(() => {
                    this.reset();
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    alert("Thank you! We'll get back to you within 24 hours.");
                }, 1500);
            }, 1200);
        });

        // Initialize everything
        function init() {
            initializeTailwind();
            renderProducts();
            
            // Optional: Add a floating cart button in nav (commented for cleanliness)
            // You can uncomment and style if desired
            
            // Keyboard escape for cart
            document.addEventListener('keydown', function(e) {
                if (e.key === "Escape") {
                    const modal = document.getElementById('cart-modal');
                    if (!modal.classList.contains('hidden')) hideCart();
                }
            });
            
            // Make "Shop" nav scroll smooth
            console.log('%c[Modern Lou & Harry\'s] Website initialized successfully.', 'color:#888');
        }

        window.onload = init;
    </script>
</body>
</html>
